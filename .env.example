# ─────────────────────────────────────────────────────────────────────────────
# AI Check AWS — Docker Compose environment (template)
# Copy this file to .env ('make up' does this automatically on first run)
# and fill in your values before starting the stack.
# Never commit .env to version control — it contains secrets.
#
# This one .env is used by the single "app" container docker-compose.yml
# starts, which serves BOTH POCs on one port:
#   - EmailPOC                  -> served at /email_poc  (+ the "/" landing page)
#   - Bedrock Availability POC  -> served at /check-bedrock
# Only fill in the EngageLab OR SendCloud block below (whichever provider you
# plan to pick from the Send RFQ page's "Provider" dropdown) and the AWS
# section for the Bedrock check.
# ─────────────────────────────────────────────────────────────────────────────


# ── Ports (host-side; change if 8000/5433 are already taken) ────────────────
APP_PORT=8000
POSTGRES_PORT=5433


# ── Database (required — do not change the hostname "db", it's the Compose
# service name; only touch the user/password/db name if you also change the
# matching POSTGRES_* values below) ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/emailpoc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=emailpoc


# ── Auth / sessions (required) ────────────────────────────────────────────
# Signs the short-lived "pending registration" cookie used between the
# registration wizard's steps. Generate one with `openssl rand -base64 32`.
SECRET_KEY=

SESSION_TTL_DAYS=7
SESSION_COOKIE_SECURE=true

# Local-dev-only login bypass used by the "Default User — John Carter"
# button on the "/" landing page (see src/auth/dev_bypass.py). Leave false
# unless you're running this stack purely for local exploration/demo.
DEV_BYPASS_LOGIN=true


# ── EmailPOC provider selection ───────────────────────────────────────────────
# There is no single "active" provider anymore — the Send RFQ page has a
# required "Provider" dropdown, and whichever provider is picked for a given
# send is built on the fly from its own {PROVIDER}_* variables below. Only
# the block(s) for the provider(s) you plan to use need to be filled in.
LOG_LEVEL=INFO


# ── EngageLab (fill in to offer "EngageLab" in the dropdown) ─────────────────
# API_USER/API_KEY from the EngageLab dashboard (Send Settings > API_USER —
# create it as "Trigger Email", NOT "Batch"). Full walkthrough:
# setup_docs/engagelab_guide/engagelab_setup.md
ENGAGELAB_API_USER=xxxxxxxxxxxxxxxxxxxxxx
ENGAGELAB_API_KEY=xxxxxxxxxxxxxxxxxxxxxx
# Region base URL (optional; Singapore is the default).
# Turkey: https://emailapi-tr.engagelab.com
ENGAGELAB_API_BASE=https://email.api.engagelab.cc
# Verified sending subdomain (its MX records point at EngageLab so inbound
# mail reaches /email_poc/webhooks/inbound), used to build the From and
# dynamic Reply-To addresses for sends made through EngageLab.
ENGAGELAB_OUTBOUND_DOMAIN=mail.yourdomain.com
# Display name shown in the From header and the email signature.
ENGAGELAB_COMPANY_NAME=Your Company


# # ── SendCloud (fill in to offer "SendCloud" in the dropdown) ─────────────────
# # API_USER and API_KEY from the SendCloud console. Outbound sending only —
# # inbound reply parsing is not implemented yet (no webhook doc available).
# SENDCLOUD_API_USER=xxxxxxxxxxxxxxxxxxxxxx
# SENDCLOUD_API_KEY=xxxxxxxxxxxxxxxxxxxxxx
# # Region base URL (optional; Singapore is the default).
# # US: https://api-us.aurorasendcloud.com   CN/HK: https://api-hk.aurorasendcloud.com
# SENDCLOUD_API_BASE=https://api.aurorasendcloud.com
# # Domain used to build the From and dynamic Reply-To addresses for sends
# # made through SendCloud. Keep equal to ENGAGELAB_OUTBOUND_DOMAIN above
# # unless the inbound webhook parser (fixed to EngageLab) is also taught to
# # check every configured domain.
# SENDCLOUD_OUTBOUND_DOMAIN=mail.yourdomain.com
# # Display name shown in the From header and the email signature.
# SENDCLOUD_COMPANY_NAME=Your Company

# # Hong Kong/CN region — used for Chinese suppliers when SendCloud is picked
# # on the Send RFQ form (see src.route._SEND_KEYS). Region-locked: this is a
# # wholly separate API_USER/API_KEY pair from SENDCLOUD_API_USER/KEY above,
# # generated under the Hong Kong region view of the SendCloud console — the
# # Singapore pair will not authenticate against this region's base URL.
# SENDCLOUD_HK_API_USER=xxxxxxxxxxxxxxxxxxxxxx
# SENDCLOUD_HK_API_KEY=xxxxxxxxxxxxxxxxxxxxxx
# # Domain used to build the From and dynamic Reply-To addresses for sends
# # made through the Hong Kong/CN region — independent of
# # SENDCLOUD_OUTBOUND_DOMAIN above, since it's verified separately against
# # this region.
# SENDCLOUD_HK_OUTBOUND_DOMAIN=mail.yourdomain.com
# # Optional; defaults to the Hong Kong/CN base URL shown here.
# SENDCLOUD_HK_API_BASE=https://api-hk.aurorasendcloud.com


# ── Bedrock Availability POC (required for the "Check Bedrock" button,
# served at /check-bedrock on this same "app" container/port) ───────────────
# AWS region to query for Bedrock foundation models.
AWS_REGION=us-east-1

# Option 1 (recommended for this POC): explicit credentials. If both are
# set, they're used regardless of anything else configured on the system.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Only needed alongside temporary credentials (assumed role / SSO session).
# AWS_SESSION_TOKEN=

# Option 2: a named profile from ~/.aws/credentials, ignored if the two
# keys above are set. Only useful if you mount ~/.aws into the container.
# AWS_PROFILE=my-profile

# Optional — direct Anthropic API check (separate from Bedrock). Set to
# also enable the "Manual Claude API Access" line in the check's result.
# Leave unset to skip it (shown as NOT CONFIGURED, not an error).
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_TEST_MODEL=claude-sonnet-5

# The "/" landing page's "Run Bedrock Check" button is built automatically
# from whatever host/port you're browsing this app on — no need to set
# anything here for local dev or a normal single-host deploy, since /check-
# bedrock is served by this same "app" container. Only set
# BEDROCK_SERVICE_URL explicitly if a reverse proxy fronts the "app"
# container under a different external host/path than the one it sees the
# request on.
# BEDROCK_SERVICE_URL=https://yourdomain.com/check-bedrock/
