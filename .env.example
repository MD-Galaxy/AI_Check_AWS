# ─────────────────────────────────────────────────────────────────────────────
# AI Check AWS — Environment Variables (template)
# Copy this file to .env and fill in your values before starting the server.
# Never commit .env to version control — it contains secrets.
#
# This project is two POCs that can run side by side:
#   - EmailPOC                  -> served at /email_poc  (+ the "/" landing page)
#   - Bedrock Availability POC  -> served at /check-bedrock (bedrock_availability_poc/)
# For the one-command Docker quick start, use .env.docker.example instead —
# it's the minimal template docker-compose.yml/Makefile expect.
# ─────────────────────────────────────────────────────────────────────────────


# ── Database (required) ──────────────────────────────────────────────────────
# Async SQLAlchemy connection string for Postgres. `docker compose up -d db`
# brings up a matching local Postgres 16 instance (see docker-compose.yml).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/emailpoc


# ── Auth / sessions (required) ────────────────────────────────────────────────
# Signs the short-lived "pending registration" cookie used between the
# registration wizard's steps. Set this explicitly (e.g. `openssl rand
# -base64 32`) for anything longer-lived than local dev — leaving it unset
# generates a fresh random key on every restart, which invalidates any
# in-progress registration.
SECRET_KEY=

# How long a login session stays valid without activity (sliding expiry).
SESSION_TTL_DAYS=7

# Set to false only for local http:// dev — the session cookie is marked
# Secure otherwise, so browsers refuse to send it over plain http.
SESSION_COOKIE_SECURE=true

# Local-dev-only login bypass used by the "Default User — John Carter"
# button on the "/" landing page (see src/auth/dev_bypass.py). The route
# 404s unless this is true — off by default so a stray deploy never exposes
# an unauthenticated login.
DEV_BYPASS_LOGIN=false


# ── Provider selection (required) ────────────────────────────────────────────
# Which email provider to use for BOTH sending and inbound webhook parsing.
# One of: sendcloud | engagelab
# Only the credentials for the selected provider are required; the app fails
# fast at startup with a clear message if the active provider is misconfigured.
# NOTE: sendcloud outbound sending is fully implemented; inbound reply
# parsing is a stub (no SendCloud inbound webhook doc yet). engagelab has
# both outbound sending and inbound reply parsing implemented — see
# setup_docs/engagelab_guide/engagelab_setup.md for the full walkthrough.
# (The code also supports sendgrid/mailgun/elasticemail via this same env
# var, but only engagelab and sendcloud are documented/used in this repo.)
EMAIL_PROVIDER=engagelab


# ── Logging (optional) ───────────────────────────────────────────────────────
# Threshold for the single shared application logger.
# One of: DEBUG | INFO | WARNING | ERROR | CRITICAL  (default: INFO)
LOG_LEVEL=INFO


# ── Shared / app-wide (required) ─────────────────────────────────────────────
# The (sub)domain whose MX records point at your provider so that inbound mail
# to *@INBOUND_DOMAIN is delivered to the /email_poc/webhooks/inbound endpoint.
# Dynamic conversation addresses look like: usr42_conv3fa9c1b2@mail.yourdomain.com
INBOUND_DOMAIN=mail.yourdomain.com

# Verified sender address used in the From header of every outbound RFQ.
FROM_EMAIL=noreply@yourdomain.com

# Display name shown in the From header and the email signature (optional;
# defaults to "Your Company").
COMPANY_NAME=Your Company


# ── EngageLab (required when EMAIL_PROVIDER=engagelab) ───────────────────────
# API_USER and API_KEY from the EngageLab dashboard (Send Settings >
# API_USER — create it as "Trigger Email", NOT "Batch"). Full setup
# walkthrough (domain auth, MX record, Inbound Route webhook) is in
# setup_docs/engagelab_guide/engagelab_setup.md
ENGAGELAB_API_USER=xxxxxxxxxxxxxxxxxxxxxx
ENGAGELAB_API_KEY=xxxxxxxxxxxxxxxxxxxxxx
# Region base URL (optional; Singapore is the default).
# Turkey: https://emailapi-tr.engagelab.com
ENGAGELAB_API_BASE=https://email.api.engagelab.cc


# # ── SendCloud (required when EMAIL_PROVIDER=sendcloud) ───────────────────────
# # API_USER and API_KEY from the SendCloud console. Outbound sending only —
# # inbound reply parsing is not implemented yet (no webhook doc available).
# SENDCLOUD_API_USER=xxxxxxxxxxxxxxxxxxxxxx
# SENDCLOUD_API_KEY=xxxxxxxxxxxxxxxxxxxxxx
# # Region base URL (optional; Singapore is the default).
# # US: https://api-us.aurorasendcloud.com   CN/HK: https://api-hk.aurorasendcloud.com
# SENDCLOUD_API_BASE=https://api.aurorasendcloud.com


# ─────────────────────────────────────────────────────────────────────────────
# Bedrock Availability POC (bedrock_availability_poc/) — required for the
# "Check Bedrock" button on the "/" landing page. These are read by that
# service's own config.py, not EmailPOC's — see
# bedrock_availability_poc/.env.example for its standalone/CLI template.
# ─────────────────────────────────────────────────────────────────────────────

# AWS region to query for Bedrock foundation models.
AWS_REGION=us-east-1

# Option 1 (recommended for this POC): provide credentials directly here.
# If both AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY are set, they are used
# instead of anything already configured on the system.
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# Only needed for temporary credentials (assumed role / SSO session) — leave
# unset for a normal long-lived access key pair.
# AWS_SESSION_TOKEN=...

# Option 2: use a named profile from ~/.aws/credentials instead (ignored if
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY above are set).
# AWS_PROFILE=my-profile

# If none of the above are set, boto3 falls back to its own default
# credential chain (env vars already in your shell, IAM role, SSO, etc.)

# Optional — direct Anthropic API check (separate from Bedrock). If set,
# also calls Claude directly via Anthropic's own API (not through AWS
# Bedrock) as an extra "Manual Claude API Access" line in the check's
# result. Leave unset to skip this check entirely (shown as NOT CONFIGURED,
# not an error).
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_TEST_MODEL=claude-sonnet-5

# Host-side port the bedrock_availability_poc service is reachable on
# (e.g. `docker run -p 8080:8080 ...`, or its own `uvicorn --port 8080`).
BEDROCK_PORT=8080

# The "/" landing page's "Run Bedrock Check" button is built automatically
# from BEDROCK_PORT above + whatever host you're browsing from — no need to
# set anything here for local dev or a normal single-host deploy. Only set
# BEDROCK_SERVICE_URL explicitly if a reverse proxy fronts the bedrock
# service on a different host/path than "<this-host>:BEDROCK_PORT".
# BEDROCK_SERVICE_URL=https://bedrock.yourdomain.com/check-bedrock/
